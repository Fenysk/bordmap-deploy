# ─────────────────────────────────────────────────────────────────────────────
# Bordmap — TEST env template for the NAS (FEN-529). Copy to `.env` ON THE NAS
# (chmod 600), fill secrets, NEVER commit the filled file. nas-deploy-bordmap.sh
# syncs the repo WITHOUT this file and reads the NAS-side `.env` via --env-file.
# This is a TEST env — it is NOT prod (bordmap.fenysk.fr stays on the Coolify VPS).
# ─────────────────────────────────────────────────────────────────────────────

# --- Exposure ----------------------------------------------------------------
# Loopback bind by default; Tailscale Serve terminates TLS on the NAS host in
# front (HTTPS finalized in the sibling HTTPS issue). For a tailnet-only HTTP
# interim with NO admin/sudo, set BIND to the NAS Tailscale IP (e.g. 100.x.y.z).
BIND=127.0.0.1
# Host ports (loopback). Off the 8090/8091 block used by LivePlace test.
APP_PORT=8092
CONVEX_API_PORT=8093
CONVEX_SITE_PORT=8094

# --- Public origins seen by the browser (behind the NAS front) ---------------
# HTTPS (Tailscale Serve, path-routed — mirrors the README NAS example):
#   VITE_CONVEX_URL=https://<magicdns>.ts.net/convex
#   CONVEX_CLOUD_ORIGIN=https://<magicdns>.ts.net/convex
#   CONVEX_SITE_ORIGIN=https://<magicdns>.ts.net/convex-site
#   SITE_URL=https://<magicdns>.ts.net
# tailnet HTTP interim (BIND=<tailscale-ip>):
#   VITE_CONVEX_URL=http://<tailscale-ip>:8093
#   CONVEX_CLOUD_ORIGIN=http://<tailscale-ip>:8093
#   CONVEX_SITE_ORIGIN=http://<tailscale-ip>:8094
#   SITE_URL=http://<tailscale-ip>:8092
VITE_CONVEX_URL=http://127.0.0.1:8093
CONVEX_CLOUD_ORIGIN=
CONVEX_SITE_ORIGIN=
SITE_URL=http://127.0.0.1:8092
# AUTH_ISSUER auto-derives to SITE_URL/api/auth when blank; set if the public URL
# differs from what the container sees. Also `convex env set AUTH_ISSUER <value>`.
AUTH_ISSUER=

# --- Convex self-host --------------------------------------------------------
# Stable admin key (recommended explicit in prod/test). Generate with the
# backend's generate_admin_key.sh, or leave blank to derive from the persisted
# instance secret in the convex-data volume (stable across restarts).
CONVEX_SELF_HOSTED_ADMIN_KEY=
DISABLE_BEACON=true

# --- Better Auth -------------------------------------------------------------
# REQUIRED: generate with `openssl rand -hex 32`. KEEP SECRET.
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# --- R2 routing (GraphHopper, FEN-507) ---------------------------------------
# INTERNAL URL of the GraphHopper resource. Blank = routing disabled (no-op).
GRAPHHOPPER_URL=

# --- Backend image pin (bump in lockstep with the `convex` npm pkg) ----------
CONVEX_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:aeb5f28adfe92f88c8c504b7883a12acfdf7cde6
