# Bordmap environment — copy to `.env.local` and fill in. NEVER commit secrets.

# --- Convex (client) ---
# PUBLIC origin the browser uses to reach Convex. Baked into the client bundle
# at build time. Local self-host = http://localhost:3210; on the NAS use the
# proxied https URL (e.g. https://bordmap.example/convex).
VITE_CONVEX_URL=http://localhost:3210

# --- Convex self-host (server) ---
# Used by `npx convex dev` / `npx convex deploy` to target the self-hosted
# backend instead of Convex Cloud.
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
# Admin key for the self-hosted backend. Generate with the backend's
# `generate_admin_key.sh`. KEEP SECRET — use a Docker secret in prod.
CONVEX_SELF_HOSTED_ADMIN_KEY=

# --- Docker (single image / fallback) ---
# Pinned to the backend release matching `convex` npm 1.40.0. The ghcr tag is the
# FULL commit sha of release `precompiled-2026-06-01-aeb5f28` (cut right after
# npm 1.40.0; multi-arch amd64+arm64). Selection rule: pick the precompiled
# release at/just after the npm version's publish date, then resolve its full
# sha (image tags are full shas). Bump in lockstep with the `convex` npm pkg.
CONVEX_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:aeb5f28adfe92f88c8c504b7883a12acfdf7cde6
# Stable instance identity for the fallback backend service.
CONVEX_INSTANCE_NAME=bordmap
CONVEX_INSTANCE_SECRET=

# PUBLIC origins the browser/CLI use to reach Convex. Leave blank for a plain
# local run (loopback defaults apply). On the NAS set these to the proxied https
# origins (typically the same host as VITE_CONVEX_URL).
CONVEX_CLOUD_ORIGIN=
CONVEX_SITE_ORIGIN=
# Self-host hygiene: disable upstream telemetry beacon.
DISABLE_BEACON=true

# --- R2 routing engine (GraphHopper, FEN-507) ---
# INTERNAL URL of the separate GraphHopper Coolify resource (never public). The
# computeRoutes Convex action reaches it server-side. On Coolify this resolves
# via container_name on the shared `coolify` network; locally point it at your
# GraphHopper container. Leave blank to disable routing (no-op until FEN-504).
GRAPHHOPPER_URL=http://bordmap-graphhopper:8989
