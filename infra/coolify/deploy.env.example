# Bordmap Coolify deploy config (FEN-437). Copy to deploy.env (gitignored) and
# fill in. The scripts also read the real environment first — the secrets
# (COOLIFY_API_TOKEN, GITHUB_TOKEN) are injected into the agent run, so you
# normally only need this file for the values the scripts persist back.

# --- Coolify ---
COOLIFY_URL=https://coolify.fenysk.fr
# COOLIFY_API_TOKEN is injected into the run (highest-numbered _N wins). Set here
# only when running by hand outside the agent.
# COOLIFY_API_TOKEN=

# Bordmap project + production environment (baked into coolify-deploy.mjs too —
# the script REFUSES any other project; these are here for visibility/override).
COOLIFY_PROJECT_UUID=mbw8fq4xd475qc35hln9ryq0
COOLIFY_ENVIRONMENT_UUID=amdffi9rkbk785eva1f3z9b2
COOLIFY_ENVIRONMENT_NAME=production
COOLIFY_APP_NAME=bordmap
# Filled by coolify-deploy.mjs after the app is created (idempotent re-runs).
# COOLIFY_APP_UUID=
# Optional: pin a single server uuid (auto-resolved if the instance has one).
# COOLIFY_SERVER_UUID=

# --- Git source (set by coolify-wire-source.mjs) ---
# COOLIFY_GIT_REPOSITORY=https://github.com/<owner>/bordmap-deploy.git
COOLIFY_GIT_BRANCH=main
COOLIFY_COMPOSE_LOCATION=/docker-compose.coolify.yml

# --- Public URL ---
# Left empty → coolify-deploy.mjs reads the Coolify-assigned domain and fills
# VITE_CONVEX_URL / SITE_URL / AUTH_ISSUER from it. Set explicitly to use a
# custom domain instead.
# PUBLIC_BASE_URL=https://bordmap.example

# --- R2 routing (GraphHopper, FEN-507) ---
# GraphHopper is a SEPARATE Coolify resource (infra/coolify/graphhopper/). The app
# reaches it on the internal `coolify` network via container_name; set this on the
# app resource so the entrypoint pushes it to the Convex env store.
GRAPHHOPPER_URL=http://bordmap-graphhopper:8989

# --- Persisted secrets (auto-generated + written back; keep stable) ---
# BETTER_AUTH_SECRET=
